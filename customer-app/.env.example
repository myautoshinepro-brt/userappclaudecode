PORT=3000
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=365d
OTP_EXPIRES_MINUTES=5

# Set to false in production (hides OTP from logs)
DEV_MODE=false

# Railway persistent volume path — set this in Railway dashboard
DB_PATH=/data/sparkwash.sqlite

# CORS — set to your frontend domain in production
# CORS_ORIGIN=https://your-customer-app.up.railway.app

# URL of the center-app service. Customer-app proxies /api/centers to ${CENTER_APP_URL}/api/public/centers.
# Default is local dev (http://localhost:3001). Set this in Railway to the deployed center-app URL.
# CENTER_APP_URL=https://userappclaudecode-production-7ece.up.railway.app

# ── SMS / OTP delivery ───────────────────────────────────────
# When a user logs in with a mobile number, the OTP is sent over SMS.
# Pick one provider. If unset, the OTP is logged to the console (dev only).
#
# Option A — MSG91 (recommended for India; cheapest, needs DLT registration)
# SMS_PROVIDER=msg91
# MSG91_AUTH_KEY=your-msg91-auth-key
# MSG91_TEMPLATE_ID=your-dlt-approved-template-id
#
# Option B — Twilio (international, ~₹0.50/SMS in India, no DLT required)
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM=+1XXXXXXXXXX
