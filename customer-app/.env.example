PORT=3000
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=30d
OTP_EXPIRES_MINUTES=5

# Set to false in production (hides OTP from logs)
DEV_MODE=false

# Railway persistent volume path — set this in Railway dashboard
DB_PATH=/data/sparkwash.sqlite

# CORS — set to your frontend domain in production
# CORS_ORIGIN=https://your-customer-app.up.railway.app
