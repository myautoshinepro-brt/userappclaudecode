PORT=3001
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=365d
OTP_EXPIRES_MINUTES=5

# Set to false in production
DEV_MODE=false

# Railway persistent volume path
DB_PATH=/data/sparkwash-center.sqlite

# CORS
# CORS_ORIGIN=https://your-center-app.up.railway.app

# Email (order summary on wash completion)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="SparkWash" <your@gmail.com>

# ── SMS / OTP delivery (login is by mobile, so SMS is primary) ──
# Pick one provider. If unset, the OTP is logged to the console (dev only).
#
# Option A — MSG91 (recommended for India)
# SMS_PROVIDER=msg91
# MSG91_AUTH_KEY=your-msg91-auth-key
# MSG91_TEMPLATE_ID=your-dlt-approved-template-id
#
# Option B — Twilio (international)
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM=+1XXXXXXXXXX
