PORT=3001
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=30d
OTP_EXPIRES_MINUTES=5

# Set to false in production
DEV_MODE=false

# Railway persistent volume path
DB_PATH=/data/sparkwash-center.sqlite

# CORS
# CORS_ORIGIN=https://your-center-app.up.railway.app

# Email (order summary on wash completion)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="SparkWash" <your@gmail.com>
